{
  "version": 2,
  "name": "schuber",
  "framework": "create-react-app",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": "build",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://schuber-api.onrender.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}